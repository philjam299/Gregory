# Gmail account that will send the notification emails
GMAIL_USER=greglifestylz@gmail.com

# App Password generated from the Gmail account (NOT the regular account password)
# See: https://myaccount.google.com/apppasswords (requires 2-Step Verification enabled)
GMAIL_APP_PASSWORD=

# Optional: where contact form notifications should be sent (defaults to GMAIL_USER)
CONTACT_TO_EMAIL=greglifestylz@gmail.com

# Optional: port for the server
PORT=3000
